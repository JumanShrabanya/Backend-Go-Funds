# Application
PORT=8000
APP_ENV=development

# Database
# APP_ENV=development uses LOCAL_DATABASE_URL.
# APP_ENV=production uses NEON_DATABASE_URL (DATABASE_URL remains supported for existing setups).
LOCAL_DATABASE_URL=postgresql://postgres:postgres@localhost:5434/gofunds
NEON_DATABASE_URL=postgresql://username:password@your-neon-host/db_name?sslmode=require

# JWT
JWT_ACCESS_SECRET=your_super_secret_access_key_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=10

# Gmail SMTP (use a Gmail App Password, not your normal Gmail password)
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASS=your-16-character-gmail-app-password
SMTP_FROM=Go Funds <your-gmail-address@gmail.com>

# Email verification OTP
OTP_EXPIRES_IN_MINUTES=15
